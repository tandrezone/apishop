              "raw": "{\n  \"total_amount\": 699.99,\n  \"status\": \"pending\",\n  \"items\": [\n    {\n      \"product_id\": 2,\n      \"quantity\": 1,\n      \"price\": 699.99\n    }\n  ]\n}"
